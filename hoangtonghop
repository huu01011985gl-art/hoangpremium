-- Hàm tạo THÔNG BÁO CHỮ ĐỎ NHẸ RÕ NÉT (Giữa màn hình)
local function NotifyRed(text)
    local NotifyGui = Instance.new("ScreenGui")
    NotifyGui.Parent = game.CoreGui
    
    local Label = Instance.new("TextLabel")
    Label.Parent = NotifyGui
    Label.Size = UDim2.new(0, 500, 0, 50)
    Label.Position = UDim2.new(0.5, -250, 0.25, 0) -- Hiện ở phía trên trung tâm
    Label.BackgroundTransparency = 1
    Label.TextColor3 = Color3.fromRGB(255, 120, 120) -- MÀU ĐỎ NHẸ (Pastel Red)
    Label.Text = text
    Label.Font = Enum.Font.GothamBold -- Phông chữ rõ nét nhất
    Label.TextSize = 22
    Label.TextStrokeTransparency = 0.3 -- Làm chữ nổi bật hẳn lên
    Label.TextStrokeColor3 = Color3.fromRGB(0, 0, 0)
    
    -- Hiệu ứng chữ mờ dần sau 3.5 giây
    task.spawn(function()
        task.wait(3.5)
        for i = 0, 1, 0.1 do
            Label.TextTransparency = i
            Label.TextStrokeTransparency = 0.3 + (i * 0.7)
            task.wait(0.05)
        end
        NotifyGui:Destroy()
    end)
end

